{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "lib": ["ES2020", "DOM"],
    "types": ["node"],
    "typeRoots": [
      "../../node/node_modules/@types"
    ],
    "paths": {
      "tryaii-dre": ["./tests/fixtures/tryaii-dre-mock.ts"],
      "vitest": ["../../node/node_modules/vitest/dist/index.d.ts"],
      "vitest/config": ["../../node/node_modules/vitest/config.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "dist"]
}
